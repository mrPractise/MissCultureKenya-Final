{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "SECRET_KEY=build-placeholder DATABASE_URL=sqlite:///tmp/build.sqlite3 python manage.py collectstatic --noinput"
  },
  "deploy": {
    "preDeployCommand": "python manage.py migrate --noinput && python manage.py ensure_superuser",
    "startCommand": "gunicorn missculture.wsgi:application --bind 0.0.0.0:$PORT --workers 3 --threads 4 --worker-class gthread --log-file - --timeout 30 --graceful-timeout 30",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
